# Variables de entorno para la API de Tareas
# ===========================================
# Copia este archivo como .env y configura tus valores

# Base de datos PostgreSQL
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public"

# Configuración de PostgreSQL para Docker
POSTGRES_DB=todo_api_db
POSTGRES_USER=todo_user
POSTGRES_PASSWORD=your_secure_password_here

# Configuración del servidor
PORT=3000
NODE_ENV=development

# Configuración de JWT (para futuras implementaciones de autenticación)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Configuración de la aplicación
API_VERSION=3.0.0
API_NAME="TODO API Professional"

# Configuración de logging
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Configuración de pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@todoapi.local
PGADMIN_DEFAULT_PASSWORD=your_admin_password_here
