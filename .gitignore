# ==========================================
# .gitignore para TODO API Professional
# ==========================================

# Dependencias de Node.js
node_modules/
.pnpm-store/

# Archivos de log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Archivos de entorno (variables de configuración)
.env
.env.*
!.env.example

# Archivos temporales del sistema
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Archivos de IDE y editores
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# Archivos de cobertura de pruebas
coverage/
*.lcov
.nyc_output/

# Archivos de distribución
dist/
build/
out/

# TypeScript
*.tsbuildinfo
.tsbuildinfo

# Base de datos local
*.db
*.sqlite
*.sqlite3

# Prisma
prisma/generated/
.env.db

# Archivos de Docker
.dockerignore

# Archivos de respaldo
*.backup
*.bak
*.tmp

# Archivos de sistema
.fuse_hidden*
.directory
.Trash-*
.nfs*

# Archivos de desarrollo temporal
test-*
debug-*
temp-*
*.temp
