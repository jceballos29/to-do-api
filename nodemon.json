{
  "watch": ["src/**/*.ts"],
  "ext": "ts,json",
  "ignore": [
    "node_modules/",
    "dist/",
    "**/*.test.ts",
    "**/*.spec.ts",
    "coverage/",
    "prisma/migrations/"
  ],
  "exec": "ts-node -r tsconfig-paths/register src/app.ts",
  "env": {
    "NODE_ENV": "development"
  },
  "delay": 2000,
  "verbose": true
}
